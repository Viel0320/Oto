<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- SAF Library Access Policy (Rely on user-selected tree grants instead of broad shared-media access) -->
    <!-- Local library roots are opened through persistable Storage Access Framework URIs, so READ_MEDIA_AUDIO stays undeclared until a MediaStore import flow exists. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <!-- WebDAV Networking (Allows remote provider to access LAN/Internet HTTP services) -->
    <!-- This is required for listing directories, reading metadata, and streaming audio playback. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Haptic Feedback Permission (Declare vibrate permission to provide physical cues when sleep timer is reset) -->
    <!-- Provides a subtle vibration feedback when the user gently shakes the phone to reset the countdown, enhancing night-time accessibility. -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <attribution android:tag="media_playback" android:label="@string/app_name" />
    <attribution android:tag="library_sync" android:label="@string/app_name" />

    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT" />
            <data android:mimeType="text/plain" />
        </intent>
        <!-- For Android Auto connection status -->
        <intent>
            <action android:name="androidx.car.app.connection.CarConnection" />
        </intent>
    </queries>

    <!-- Heap Expansion Policy (Enable largeHeap attribute to request a larger Java heap memory allocation) -->
    <!-- This mitigates potential OOM crashes when parsing multiple large-sized .m4b audiobook files, which allocate massive sample size arrays under Media3. -->
    <application
        android:name=".APlayerApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.APlayer"
        android:localeConfig="@xml/locales_config"
        android:enableOnBackInvokedCallback="true"
        tools:targetApi="36"
        android:largeHeap="true"
        android:networkSecurityConfig="@xml/network_security_config">
        <!-- Android App Language Picker (Expose the supported locale list to platform settings)
             The localeConfig resource powers Android 13+ per-app language selection and shares the same language set as the in-app picker. -->
        <!-- 
             Soft Keyboard Window Mode (Configure MainActivity windowSoftInputMode to adjustNothing)
         This prevents the system from resizing the root window when the IME keyboard appears, keeping the underlying HomeScreen stable.
         This avoids visual glitches or flickers in the real-time frosted glass backdrop sampling, while layout padding adjustments are handled via Compose insets. -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:windowSoftInputMode="adjustNothing"
            android:theme="@style/Theme.APlayer">
            <!-- SingleTop Launch Behavior (Ensure widget clicks reuse the existing MainActivity instance)
                 Launches via singleTop so that onNewIntent can intercept the event to bring up the player overlay sheet. -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>




        <!-- Widget Broadcast Receiver (Register PlayerWidgetReceiver for handling system-triggered desktop widget updates)
             All custom media control actions are detached to prevent malicious external processes from hijacking playback or forcing service starts. -->
        <receiver
            android:name=".widget.PlayerWidgetReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/player_widget_info" />
        </receiver>

        <!-- Playback Action Broadcast Receiver (Register local PlayerWidgetActionReceiver to handle widget media actions)
             Explicitly configured with android:exported="false" to restrict access to local package context and drop spoofed external intents. -->
        <receiver
            android:name=".widget.PlayerWidgetActionReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="com.viel.aplayer.widget.ACTION_REWIND" />
                <action android:name="com.viel.aplayer.widget.ACTION_FORWARD" />
                <action android:name="com.viel.aplayer.widget.ACTION_PLAY_PAUSE" />
            </intent-filter>
        </receiver>

        <!-- 
             File Sharing Provider (Declare FileProvider to facilitate secure, cross-process data sharing)
             Provides temporary URI read permissions to system components (e.g., SystemUI MediaDataManager) for accessing cached covers.
             Utilizes content:// schemes to comply with sandboxing policies, completely eliminating physical path-related ENOENT file errors.
        -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.viel.aplayer.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Playback Service Registration (Fix crash by declaring PlaybackService in manifest)
             This declares PlaybackService in the AndroidManifest with the required androidx.media3.session.MediaSessionService intent action to resolve SessionToken creation, and sets the foreground service type to mediaPlayback to prevent runtime permission errors on Android 14+. -->
        <service
            android:name=".media.service.PlaybackService"
            android:foregroundServiceType="mediaPlayback"
            android:exported="true"
            tools:ignore="ExportedService">
            <intent-filter>
                <action android:name="androidx.media3.session.MediaSessionService" />
            </intent-filter>
        </service>
    </application>
</manifest>
