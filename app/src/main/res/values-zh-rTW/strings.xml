    <string name="about_version_text">版本 1.0 (Beta)</string>
    <string name="about_app_description">APlayer 是為聽書愛好者打造的本機有聲書播放器。優秀產品離不開開源社群的基礎貢獻，謹向讓本應用程式成為可能的程式庫作者與組織致敬。</string>
    <string name="about_developer_credit">由 %1$s 提供</string>
    <string name="about_visit_project_homepage_content_description">造訪專案首頁</string>
    <string name="about_license_details_title">詳細授權聲明</string>
    <string name="about_visit_project_homepage">造訪專案首頁 (GitHub / Maven)</string>
    <string name="about_library_compose_description">Jetpack Compose 是用於建構原生 Android 介面的現代宣告式工具包，提供更少程式碼、強大工具和直覺 Kotlin API。</string>
    <string name="about_library_media3_description">Media3 是新一代 AndroidX 媒體技術堆疊，包含 ExoPlayer。APlayer 使用它處理有聲書串流載入、斷點續播和硬體播放。</string>
    <string name="about_library_room_description">Room 在 SQLite 之上提供抽象層，支撐 APlayer 的本機詮釋資料、播放進度和斷點持久化。</string>
    <string name="about_library_haze_description">Haze 為 Jetpack Compose 提供高效能模糊效果。APlayer 使用它呈現玻璃質感面板、彈窗、徽章和播放器介面。</string>
    <string name="about_library_coil_description">Coil 是由 Kotlin 協程驅動的高速 Android 圖片載入庫。APlayer 使用它載入、快取和解碼有聲書封面。</string>
    <string name="about_library_glance_description">Glance 讓開發者用 Compose 風格宣告式 API 建構桌面小工具。APlayer 使用它提供現代高效的桌面媒體控制。</string>
    <string name="about_library_coroutines_description">Kotlin 協程為媒體掃描、網路分析和資料庫查詢提供輕量非同步執行與並行控制。</string>
    <string name="about_library_datastore_description">DataStore 是 SharedPreferences 的現代替代方案。APlayer 使用它透過 Flow 非同步儲存全域設定與偏好。</string>
