<!--
  Animated subtitles tab icon matching subtitle_outline.xml.

  Selected end state is a KNOCKOUT: a solid white card with the caption glyph
  punched out as transparent holes, so the themed bar background shows through
  the marks instead of the marks being painted on top.

  The glyph keeps the exact subtitle_outline.xml shape — three full-width caption
  lines. The lines don't overlap, so each is a separate even-odd capsule hole
  with round ends matching the original round-cap strokes.

  Two synchronized motions:
   1. A clipped white card body (caption lines pre-cut as even-odd holes)
      expands upward from below the viewport, revealing the card bottom to top.
   2. The white caption strokes fade out while the card border stays white, so
      once the body is revealed only the knocked-out glyph remains inside an
      unchanged white card.

  Because the holes reuse the caption strokes' own geometry, the start frame
  matches subtitle_outline.xml exactly and the reveal has no shape jump.
-->
<animated-vector
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt">

    <aapt:attr name="android:drawable">
        <vector
            android:width="24dp"
            android:height="24dp"
            android:viewportWidth="48"
            android:viewportHeight="48">
            <group android:name="bodyFillClipGroup">
                <clip-path
                    android:name="bodyFillClip"
                    android:pathData="M-4,52L52,52L52,52L-4,52Z" />
                <path
                    android:name="bodyFill"
                    android:fillColor="#FFFFFFFF"
                    android:fillType="evenOdd"
                    android:pathData="M10,4L38,4A2,2 0,0 1,40 6L40,42A2,2 0,0 1,38 44L10,44A2,2 0,0 1,8 42L8,6A2,2 0,0 1,10 4z M14,14L34,14A2,2 0,0 1,34 18L14,18A2,2 0,0 1,14 14Z M14,22L34,22A2,2 0,0 1,34 26L14,26A2,2 0,0 1,14 22Z M14,30L34,30A2,2 0,0 1,34 34L14,34A2,2 0,0 1,14 30Z" />
            </group>

            <!--
              The card border stays white the whole time (independent path, never
              fades) so the selected card keeps its full size and corner radius —
              strokeWidth 4 extends the edge ~2px past the fill and the round join
              rounds the corners beyond the fill's own arcs.
            -->
            <path
                android:name="cardOutline"
                android:fillColor="#00000000"
                android:strokeColor="#FFFFFFFF"
                android:strokeWidth="4"
                android:strokeLineCap="round"
                android:strokeLineJoin="round"
                android:pathData="M10,4L38,4A2,2 0,0 1,40 6L40,42A2,2 0,0 1,38 44L10,44A2,2 0,0 1,8 42L8,6A2,2 0,0 1,10 4z" />

            <!--
              Only the caption strokes fade out, leaving the knocked-out glyph in
              the body. The card border above is untouched.
            -->
            <path
                android:name="captionMarks"
                android:fillColor="#00000000"
                android:strokeColor="#FFFFFFFF"
                android:strokeWidth="4"
                android:strokeAlpha="1"
                android:strokeLineCap="round"
                android:strokeLineJoin="round"
                android:pathData="M14,16H34 M14,24H34 M14,32H34" />
        </vector>
    </aapt:attr>

    <target android:name="bodyFillClip">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:duration="300"
                android:interpolator="@android:interpolator/fast_out_slow_in"
                android:propertyName="pathData"
                android:valueFrom="M-4,52L52,52L52,52L-4,52Z"
                android:valueTo="M-4,-4L52,-4L52,52L-4,52Z"
                android:valueType="pathType" />
        </aapt:attr>
    </target>

    <target android:name="captionMarks">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:duration="180"
                android:startOffset="120"
                android:interpolator="@android:interpolator/fast_out_slow_in"
                android:propertyName="strokeAlpha"
                android:valueFrom="1"
                android:valueTo="0"
                android:valueType="floatType" />
        </aapt:attr>
    </target>
</animated-vector>
