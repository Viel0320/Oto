    <string name="about_library_compose_description">Jetpack Compose is a modern declarative toolkit for building native Android interfaces with less code, strong tooling, and intuitive Kotlin APIs.</string>
    <string name="about_library_media3_description">Media3 is the modern AndroidX media stack, including ExoPlayer. APlayer uses it for asynchronous audiobook stream loading, seamless resume, and hardware-backed playback.</string>
    <string name="about_library_room_description">Room provides an abstraction over SQLite and powers APlayer local metadata, playback progress, and resume-point persistence.</string>
    <string name="about_library_haze_description">Haze provides high-performance blur effects for Jetpack Compose. APlayer uses it for glass-like panels, dialogs, badges, and player surfaces.</string>
    <string name="about_library_coil_description">Coil is a fast Android image loading library powered by Kotlin coroutines. APlayer uses it to load, cache, and decode audiobook cover art.</string>
    <string name="about_library_glance_description">Glance lets developers build app widgets with Compose-style declarative APIs. APlayer uses it for modern, efficient desktop media controls.</string>
    <string name="about_library_coroutines_description">Kotlin Coroutines provide lightweight asynchronous execution and concurrency control for media scanning, network analysis, and database queries.</string>
    <string name="about_library_datastore_description">DataStore is a modern replacement for SharedPreferences. APlayer uses it to store global settings and preferences asynchronously with Flow.</string>
    <string name="about_library_workmanager_description">WorkManager schedules reliable background work. APlayer uses it for media library synchronization and maintenance tasks.</string>

