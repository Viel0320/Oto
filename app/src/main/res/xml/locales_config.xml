<?xml version="1.0" encoding="utf-8"?>
<!-- App Locale Configuration (Advertise supported per-app languages to Android)
     Android 13+ reads this list for the system-level app language picker, while the in-app setting uses the same locale tags. -->
<locale-config xmlns:android="http://schemas.android.com/apk/res/android">
    <locale android:name="en" />
    <locale android:name="zh-Hans-CN" />
    <locale android:name="zh-Hant-HK" />
    <locale android:name="zh-Hant-TW" />
    <locale android:name="ja" />
    <locale android:name="fr" />
    <locale android:name="de" />
    <locale android:name="ru" />
    <locale android:name="es" />
    <locale android:name="pt" />
</locale-config>
