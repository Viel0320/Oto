    <string name="about_app_description">APlayer é um leitor local de audiolivros para ouvintes
        dedicados. Grandes produtos assentam no open source, e agradecemos aos autores e
        organizações que tornam esta aplicação possível.</string>
    <string name="about_developer_credit">por %1$s</string>
    <string name="about_visit_project_homepage_content_description">Visitar página do projeto</string>
    <string name="about_license_details_title">Aviso de licença detalhado</string>
    <string name="about_visit_project_homepage">Visitar página do projeto (GitHub / Maven)</string>
    <string name="about_library_compose_description">Jetpack Compose é um kit declarativo moderno
        para criar interfaces Android nativas com menos código, boas ferramentas e API Kotlin
        intuitivas.</string>
    <string name="about_library_media3_description">Media3 é a pilha multimédia moderna do AndroidX,
        incluindo ExoPlayer. APlayer usa-a para carregar streams, retomar e reproduzir com suporte
        de hardware.</string>
    <string name="about_library_room_description">Room abstrai SQLite e mantém metadados locais,
        progresso de reprodução e pontos de retoma do APlayer.</string>
    <string name="about_library_haze_description">Haze fornece efeitos de desfoque de alto
        desempenho para Jetpack Compose. APlayer usa-o em painéis, diálogos, emblemas e superfícies
        do leitor.</string>
    <string name="about_library_coil_description">Coil é uma biblioteca rápida de carregamento de
        imagens Android baseada em Kotlin Coroutines. APlayer usa-a para capas de audiolivros.</string>
    <string name="about_library_glance_description">Glance permite criar widgets com API
        declarativas ao estilo Compose. APlayer usa-o para controlos multimédia eficientes no
        ambiente de trabalho.</string>
    <string name="about_library_coroutines_description">Kotlin Coroutines oferece execução
        assíncrona leve para análise multimédia, rede e consultas de base de dados.</string>
    <string name="about_library_datastore_description">DataStore é uma substituição moderna de
        SharedPreferences. APlayer usa-o para guardar definições globais com Flow.</string>
    <string name="about_library_workmanager_description">WorkManager agenda trabalho fiável em
        segundo plano. APlayer usa-o para sincronização e manutenção da biblioteca.</string>
