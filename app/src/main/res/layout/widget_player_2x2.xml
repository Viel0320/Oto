<?xml version="1.0" encoding="utf-8"?>
<!-- Widget Root Layout (Use RelativeLayout as the outer shell to allow cover art to stretch fully while positioning content at the bottom) -->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_click_area"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111111">

    <!-- Widget Cover Image (Cover art is loaded as full background, isolated from text measurements to prevent control layouts from squeezing) -->
    <ImageView
        android:id="@+id/widget_cover"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:adjustViewBounds="false"
        android:contentDescription="@string/player_widget_cover_description"
        android:scaleType="centerCrop" />

    <!-- Widget Cover Overlay (Semi-transparent dark layer on top of cover image to preserve text readability when bright covers are loaded) -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#66000000" />

    <!-- Bottom Scrim Overlay (Align bottom scrim helper to parent bottom to guarantee legible title and buttons overlay) -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="108dp"
        android:layout_alignParentBottom="true"
        android:background="@drawable/widget_bottom_scrim" />

    <!-- Content Container (LinearLayout grouping title and controls vertically to guarantee title sits above buttons) -->
    <LinearLayout
        android:id="@+id/widget_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="9dp"
        android:gravity="center"
        android:orientation="vertical">

        <!-- Text Details Group (Group title and author text with tight side margins to prevent premature truncation in 2x2 layout constraints) -->
        <LinearLayout
            android:id="@+id/widget_text_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:layout_marginBottom="26dp"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="sans"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:shadowColor="#CC000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="4"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:ellipsize="end"
                android:fontFamily="sans"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:shadowColor="#CC000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="4"
                android:textColor="#EDEDED"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Button Control Area (Split control area into three equal-weight columns to prevent horizontal truncation under narrow widget bounds) -->
        <LinearLayout
            android:id="@+id/widget_controls"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:weightSum="3">

            <ImageButton
                android:id="@+id/widget_skip_backward"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:contentDescription="@string/player_widget_skip_backward"
                android:padding="6dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_replay_10" />

            <!-- Play Pause Control Fallback (Initial widget layout defaults to the play icon before Glance receives playback state, so the static accessibility label announces the same concrete action) -->
            <ImageButton
                android:id="@+id/widget_play_pause"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@drawable/widget_play_control_background"
                android:contentDescription="@string/playback_play_content_description"
                android:padding="10dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_widget_play" />

            <ImageButton
                android:id="@+id/widget_skip_forward"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:contentDescription="@string/player_widget_skip_forward"
                android:padding="6dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_forward_30" />
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>
